<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.UI.ViewModels"
             xmlns:views="using:KafkaLoad.UI.Views"
             x:DataType="vm:ClientsConfigViewModel"
             x:Class="KafkaLoad.UI.Views.ClientsConfigView">

    <UserControl.Styles>
        <Style Selector="Border.notification">
            <Setter Property="Background" Value="#22C55E"/>
        </Style>
        <Style Selector="Border.notification.error">
            <Setter Property="Background" Value="#E53E3E"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="{DynamicResource AppBackground}" ColumnDefinitions="450, 8, *">

        <!-- Left panel: two lists (producers / consumers) -->
        <Border Grid.Column="0" Classes="card" Padding="12" Margin="8,8,0,8">
            <Grid RowDefinitions="Auto, Auto, *, Auto, Auto, Auto, Auto, *, Auto">

                <!-- Producers header + sort -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Producers"
                               FontWeight="Bold" FontSize="14"
                               Foreground="{DynamicResource PrimaryBlue}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" Classes="sort"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedProducerSort}"
                              MinWidth="105"/>
                </Grid>

                <!-- Producers search -->
                <TextBox Grid.Row="1" Classes="search"
                         Text="{Binding ProducerSearchText}"
                         Watermark="Search producers..."
                         Margin="0,0,0,6"/>

                <!-- Producers list -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredProducers}"
                         SelectedItem="{Binding SelectedProducer}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Producers buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="5"
                            Margin="0,6,0,4" HorizontalAlignment="Right">
                    <Button Classes="tool" Command="{Binding CreateProducerCommand}" Content="Add"/>
                    <Button Classes="tool" Command="{Binding DuplicateProducerCommand}" Content="Copy"/>
                    <Button Classes="delete" Command="{Binding DeleteProducerCommand}" Content="Del"/>
                </StackPanel>

                <!-- Divider -->
                <Separator Grid.Row="4" Height="1" Background="{DynamicResource BorderColor}"
                           Margin="0,4,0,8"/>

                <!-- Consumers header + sort -->
                <Grid Grid.Row="5" ColumnDefinitions="*, Auto" Margin="0,0,0,6">
                    <TextBlock Grid.Column="0" Text="Consumers"
                               FontWeight="Bold" FontSize="14"
                               Foreground="{DynamicResource PrimaryBlue}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" Classes="sort"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedConsumerSort}"
                              MinWidth="105"/>
                </Grid>

                <!-- Consumers search -->
                <TextBox Grid.Row="6" Classes="search"
                         Text="{Binding ConsumerSearchText}"
                         Watermark="Search consumers..."
                         Margin="0,0,0,6"/>

                <!-- Consumers list -->
                <ListBox Grid.Row="7"
                         ItemsSource="{Binding FilteredConsumers}"
                         SelectedItem="{Binding SelectedConsumer}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Consumers buttons -->
                <StackPanel Grid.Row="8" Orientation="Horizontal" Spacing="5"
                            Margin="0,6,0,0" HorizontalAlignment="Right">
                    <Button Classes="tool" Command="{Binding CreateConsumerCommand}" Content="Add"/>
                    <Button Classes="tool" Command="{Binding DuplicateConsumerCommand}" Content="Copy"/>
                    <Button Classes="delete" Command="{Binding DeleteConsumerCommand}" Content="Del"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Right panel: editor -->
        <Grid Grid.Column="2" Margin="0,8,8,8">

            <Border Classes="card" IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TransitioningContentControl Content="{Binding CurrentEditor}">
                    <TransitioningContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type vm:ProducerConfigViewModel}">
                            <views:ProducerConfigView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ConsumerConfigViewModel}">
                            <views:ConsumerConfigView/>
                        </DataTemplate>
                    </TransitioningContentControl.DataTemplates>
                </TransitioningContentControl>
            </Border>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                        IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNull}}">
                <TextBlock Text="Select or create a configuration"
                           FontSize="20" FontWeight="Light"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Use the Add button to create a new producer or consumer config"
                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Border Classes="notification" Classes.error="{Binding NotificationIsError}"
                    CornerRadius="6" Padding="14,10"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="20"
                    IsVisible="{Binding NotificationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding NotificationMessage}" Foreground="White" FontWeight="Bold"/>
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                    </Transitions>
                </Border.Transitions>
            </Border>
        </Grid>

    </Grid>
</rxui:ReactiveUserControl>
