<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.UI.ViewModels"
             xmlns:views="using:KafkaLoad.UI.Views"
             x:DataType="vm:ClientsConfigViewModel"
             x:Class="KafkaLoad.UI.Views.ClientsConfigView">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: two lists (producers / consumers) -->
        <Border Grid.Column="0" Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="*, Auto, *, Auto">

                <!-- Producers -->
                <Grid Grid.Row="0" RowDefinitions="Auto, *" Margin="12,12,12,0">
                    <TextBlock Grid.Row="0" Text="Producers"
                               FontWeight="Bold" FontSize="14"
                               Foreground="{DynamicResource PrimaryBlue}"
                               Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Producers}"
                             SelectedItem="{Binding SelectedProducer}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="5"
                            Margin="12,6,12,10" HorizontalAlignment="Right">
                    <Button Classes="tool" Command="{Binding CreateProducerCommand}" Content="Add"/>
                    <Button Classes="tool" Command="{Binding DuplicateProducerCommand}" Content="Copy"/>
                    <Button Classes="delete" Command="{Binding DeleteProducerCommand}" Content="Del"/>
                </StackPanel>

                <!-- Divider -->
                <Separator Grid.Row="1" Height="1" Background="{DynamicResource BorderColor}"
                           VerticalAlignment="Bottom" Margin="12,0"/>

                <!-- Consumers -->
                <Grid Grid.Row="2" RowDefinitions="Auto, *" Margin="12,12,12,0">
                    <TextBlock Grid.Row="0" Text="Consumers"
                               FontWeight="Bold" FontSize="14"
                               Foreground="{DynamicResource PrimaryBlue}"
                               Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Consumers}"
                             SelectedItem="{Binding SelectedConsumer}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="5"
                            Margin="12,6,12,12" HorizontalAlignment="Right">
                    <Button Classes="tool" Command="{Binding CreateConsumerCommand}" Content="Add"/>
                    <Button Classes="tool" Command="{Binding DuplicateConsumerCommand}" Content="Copy"/>
                    <Button Classes="delete" Command="{Binding DeleteConsumerCommand}" Content="Del"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Right panel: editor -->
        <Grid Grid.Column="1" Margin="16">

            <Border Classes="card" IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TransitioningContentControl Content="{Binding CurrentEditor}">
                    <TransitioningContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type vm:ProducerConfigViewModel}">
                            <views:ProducerConfigView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ConsumerConfigViewModel}">
                            <views:ConsumerConfigView/>
                        </DataTemplate>
                    </TransitioningContentControl.DataTemplates>
                </TransitioningContentControl>
            </Border>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                        IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNull}}">
                <TextBlock Text="Select or create a configuration"
                           FontSize="20" FontWeight="Light"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Use the Add button to create a new producer or consumer config"
                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Border Background="#22C55E" CornerRadius="6" Padding="14,10"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="20"
                    IsVisible="{Binding NotificationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding NotificationMessage}" Foreground="White" FontWeight="Bold"/>
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                    </Transitions>
                </Border.Transitions>
            </Border>
        </Grid>

    </Grid>
</rxui:ReactiveUserControl>
