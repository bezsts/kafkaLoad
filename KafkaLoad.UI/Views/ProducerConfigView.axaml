<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.UI.ViewModels"
             xmlns:views="using:KafkaLoad.UI.Views"
             xmlns:enums="using:KafkaLoad.Core.Enums"
             xmlns:behaviors="using:KafkaLoad.UI.Behaviors"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="KafkaLoad.UI.Views.ProducerConfigView"
             x:DataType="vm:ProducerConfigViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Border.section-card">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
        <Style Selector="Button.field-reset">
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>
        <Style Selector="Grid.label-row TextBlock.field-label">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="20">

            <!-- Name + Client ID -->
            <Grid ColumnDefinitions="*, 16, *">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="CONFIG NAME" Classes="field-label"/>
                    <TextBox Name="NameTextBox" Text="{Binding Name}"
                             Watermark="e.g. local-producer"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="CLIENT ID" Classes="field-label"/>
                    <TextBox Text="{Binding ClientID}"
                             Watermark="e.g. kafkaload-producer-1"/>
                </StackPanel>
            </Grid>

            <!-- Delivery + Performance side by side -->
            <Grid ColumnDefinitions="*, 10, *">

                <!-- Delivery settings -->
                <Border Grid.Column="0" Classes="section-card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Delivery Settings" Classes="section-title"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="ACKS (DURABILITY)" Classes="field-label"/>
                            <WrapPanel Orientation="Horizontal">
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsAcksNone, Mode=OneWay}"
                                              Command="{Binding SetAcksCommand}"
                                              CommandParameter="{x:Static enums:AcksEnum.None}"
                                              Content="None"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsAcksLeader, Mode=OneWay}"
                                              Command="{Binding SetAcksCommand}"
                                              CommandParameter="{x:Static enums:AcksEnum.Leader}"
                                              Content="Leader"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsAcksAll, Mode=OneWay}"
                                              Command="{Binding SetAcksCommand}"
                                              CommandParameter="{x:Static enums:AcksEnum.All}"
                                              Content="All"/>
                            </WrapPanel>
                        </StackPanel>

                        <CheckBox IsChecked="{Binding EnableIdempotence}"
                                  Content="Enable Idempotence"/>

                        <StackPanel Spacing="4">
                            <Grid Classes="label-row" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="RETRIES" Classes="field-label"/>
                                <Button Grid.Column="1" Content="↺" Classes="field-reset"
                                        ToolTip.Tip="Reset to default" Command="{Binding ResetRetriesCommand}"/>
                            </Grid>
                            <NumericUpDown Value="{Binding Retries, TargetNullValue={x:Null}}"
                                           Minimum="0" Maximum="2147483647" Increment="1"
                                           FormatString="N0"
                                           behaviors:NumericSpaceSeparatorBehavior.IsEnabled="True"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="COMPRESSION TYPE" Classes="field-label"/>
                            <WrapPanel Orientation="Horizontal">
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsCompressionNone, Mode=OneWay}"
                                              Command="{Binding SetCompressionCommand}"
                                              CommandParameter="{x:Static enums:CompressionTypeEnum.None}"
                                              Content="None"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsCompressionGzip, Mode=OneWay}"
                                              Command="{Binding SetCompressionCommand}"
                                              CommandParameter="{x:Static enums:CompressionTypeEnum.Gzip}"
                                              Content="Gzip"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsCompressionSnappy, Mode=OneWay}"
                                              Command="{Binding SetCompressionCommand}"
                                              CommandParameter="{x:Static enums:CompressionTypeEnum.Snappy}"
                                              Content="Snappy"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsCompressionLz4, Mode=OneWay}"
                                              Command="{Binding SetCompressionCommand}"
                                              CommandParameter="{x:Static enums:CompressionTypeEnum.Lz4}"
                                              Content="LZ4"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsCompressionZstd, Mode=OneWay}"
                                              Command="{Binding SetCompressionCommand}"
                                              CommandParameter="{x:Static enums:CompressionTypeEnum.Zstd}"
                                              Content="Zstd"/>
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Performance settings -->
                <Border Grid.Column="2" Classes="section-card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Performance Settings" Classes="section-title"/>

                        <StackPanel Spacing="4">
                            <Grid Classes="label-row" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="BATCH SIZE (BYTES)" Classes="field-label"/>
                                <Button Grid.Column="1" Content="↺" Classes="field-reset"
                                        ToolTip.Tip="Reset to default" Command="{Binding ResetBatchSizeCommand}"/>
                            </Grid>
                            <NumericUpDown Value="{Binding BatchSize, TargetNullValue={x:Null}}"
                                           Minimum="0" Maximum="52428800" Increment="4096" FormatString="N0"
                                           behaviors:NumericSpaceSeparatorBehavior.IsEnabled="True"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <Grid Classes="label-row" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="LINGER (MS)" Classes="field-label"/>
                                <Button Grid.Column="1" Content="↺" Classes="field-reset"
                                        ToolTip.Tip="Reset to default" Command="{Binding ResetLingerCommand}"/>
                            </Grid>
                            <NumericUpDown Value="{Binding Linger, TargetNullValue={x:Null}}"
                                           Minimum="0" Maximum="10000" Increment="5"
                                           FormatString="N0"
                                           behaviors:NumericSpaceSeparatorBehavior.IsEnabled="True"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <Grid Classes="label-row" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="BUFFER MEMORY (BYTES)" Classes="field-label"/>
                                <Button Grid.Column="1" Content="↺" Classes="field-reset"
                                        ToolTip.Tip="Reset to default" Command="{Binding ResetBufferMemoryCommand}"/>
                            </Grid>
                            <NumericUpDown Value="{Binding BufferMemory, TargetNullValue={x:Null}}"
                                           Minimum="1" Increment="1048576" FormatString="N0"
                                           behaviors:NumericSpaceSeparatorBehavior.IsEnabled="True"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <Grid Classes="label-row" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="MAX IN-FLIGHT REQUESTS" Classes="field-label"/>
                                <Button Grid.Column="1" Content="↺" Classes="field-reset"
                                        ToolTip.Tip="Reset to default" Command="{Binding ResetMaxInFlightCommand}"/>
                            </Grid>
                            <NumericUpDown Value="{Binding MaxInFlightRequestsPerConnection, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="100" Increment="1"
                                           FormatString="N0"
                                           behaviors:NumericSpaceSeparatorBehavior.IsEnabled="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Security settings (full width) -->
            <Border Classes="section-card">
                <StackPanel Spacing="10">
                    <TextBlock Text="Security Settings" Classes="section-title"/>
                    <views:SecurityConfigView DataContext="{Binding SecurityVM}"/>
                </StackPanel>
            </Border>

            <StackPanel HorizontalAlignment="Right" Spacing="6">
                <TextBlock Text="{Binding ValidationSummary}"
                           Foreground="#E53E3E"
                           FontSize="12"
                           TextWrapping="Wrap"
                           MaxWidth="520"
                           HorizontalAlignment="Right"
                           IsVisible="{Binding ValidationSummary,
                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <Button Command="{Binding SaveCommand}"
                        Content="Save Configuration"
                        Classes="accent"
                        HorizontalAlignment="Right"
                        Padding="24,10"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</rxui:ReactiveUserControl>
