<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.UI.ViewModels"
             xmlns:views="using:KafkaLoad.UI.Views"
             x:Class="KafkaLoad.UI.Views.TestScenariosView"
             x:DataType="vm:TestScenariosViewModel">

    <Grid Background="{DynamicResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: list -->
        <Border Grid.Column="0" Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="12">

                <TextBlock Grid.Row="0" Text="Scenarious"
                           FontWeight="Bold" FontSize="16"
                           Foreground="{DynamicResource PrimaryBlue}"
                           Margin="0,0,0,10"/>

                <!-- Search -->
                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                        CornerRadius="4" Background="White" Margin="0,0,0,10" Padding="8,6">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBox Grid.Column="0" Text="{Binding SearchText}"
                                 Watermark="Search..."
                                 BorderThickness="0" Background="Transparent"
                                 Padding="0" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="🔍" FontSize="13"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Scenarios list -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredScenarios}"
                         SelectedItem="{Binding SelectedScenario}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding TestType}" FontSize="11"
                                           Foreground="{DynamicResource PrimaryBlue}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Action buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="5"
                            Margin="0,10,0,0" HorizontalAlignment="Right">
                    <Button Classes="tool" Command="{Binding CreateCommand}" Content="Add"/>
                    <Button Classes="tool" Command="{Binding DuplicateCommand}" Content="Copy"/>
                    <Button Classes="delete" Command="{Binding DeleteCommand}" Content="Delete"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right panel: editor -->
        <Grid Grid.Column="1" Margin="16">

            <Border Classes="card" IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TransitioningContentControl Content="{Binding CurrentEditor}">
                    <TransitioningContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type vm:TestScenarioEditorViewModel}">
                            <views:TestScenarioEditorView/>
                        </DataTemplate>
                    </TransitioningContentControl.DataTemplates>
                </TransitioningContentControl>
            </Border>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                        IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNull}}">
                <TextBlock Text="Select or create a scenario"
                           FontSize="20" FontWeight="Light"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Use the Add button to create a new scenario"
                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Border Background="#22C55E" CornerRadius="6" Padding="14,10"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="20"
                    IsVisible="{Binding NotificationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding NotificationMessage}" Foreground="White" FontWeight="Bold"/>
            </Border>
        </Grid>
    </Grid>
</rxui:ReactiveUserControl>
