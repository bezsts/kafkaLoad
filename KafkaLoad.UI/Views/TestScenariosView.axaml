<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.UI.ViewModels"
             xmlns:views="using:KafkaLoad.UI.Views"
             xmlns:enums="using:KafkaLoad.Core.Enums"
             x:Class="KafkaLoad.UI.Views.TestScenariosView"
             x:DataType="vm:TestScenariosViewModel">


    <Grid Background="{DynamicResource AppBackground}" ColumnDefinitions="450, 8, *">

        <!-- Left panel: list -->
        <Border Grid.Column="0" Classes="card" Padding="12" Margin="8,8,0,8">
            <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">

                <!-- Title -->
                <TextBlock Grid.Row="0" Text="Scenarios"
                           FontWeight="Bold" FontSize="16"
                           Foreground="{DynamicResource PrimaryBlue}"
                           Margin="0,0,0,10"/>

                <!-- Search -->
                <TextBox Grid.Row="1" Classes="search"
                         Text="{Binding SearchText}"
                         Watermark="Search scenarios..."
                         Margin="0,0,0,8"/>

                <!-- Filter chips + Sort -->
                <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                    <WrapPanel Grid.Column="0" Orientation="Horizontal">
                        <ToggleButton Classes="filter" Margin="0,0,4,4"
                                      IsChecked="{Binding IsFilterAll, Mode=OneWay}"
                                      Command="{Binding SetFilterCommand}"
                                      CommandParameter="{x:Null}"
                                      Content="All"/>
                        <ToggleButton Classes="filter" Margin="0,0,4,4"
                                      IsChecked="{Binding IsFilterLoad, Mode=OneWay}"
                                      Command="{Binding SetFilterCommand}"
                                      CommandParameter="{x:Static enums:TestType.Load}"
                                      Content="Load"/>
                        <ToggleButton Classes="filter" Margin="0,0,4,4"
                                      IsChecked="{Binding IsFilterStress, Mode=OneWay}"
                                      Command="{Binding SetFilterCommand}"
                                      CommandParameter="{x:Static enums:TestType.Stress}"
                                      Content="Stress"/>
                        <ToggleButton Classes="filter" Margin="0,0,4,4"
                                      IsChecked="{Binding IsFilterSpike, Mode=OneWay}"
                                      Command="{Binding SetFilterCommand}"
                                      CommandParameter="{x:Static enums:TestType.Spike}"
                                      Content="Spike"/>
                        <ToggleButton Classes="filter" Margin="0,0,4,4"
                                      IsChecked="{Binding IsFilterSoak, Mode=OneWay}"
                                      Command="{Binding SetFilterCommand}"
                                      CommandParameter="{x:Static enums:TestType.Soak}"
                                      Content="Soak"/>
                    </WrapPanel>
                    <ComboBox Grid.Column="1" Classes="sort"
                              VerticalAlignment="Top"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSort}"
                              MinWidth="105"/>
                </Grid>

                <!-- Scenarios list -->
                <ListBox Grid.Row="3"
                         ItemsSource="{Binding FilteredScenarios}"
                         SelectedItem="{Binding SelectedScenario}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding TestType}" FontSize="11"
                                           Foreground="{DynamicResource PrimaryBlue}"/>
                                <TextBlock Text="⚠ Missing producer or consumer config"
                                           FontSize="10" Foreground="#EF4444"
                                           IsVisible="{Binding !IsConfigValid}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Action buttons -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="5"
                            Margin="0,10,0,0" HorizontalAlignment="Right">
                    <Button Classes="tool" Command="{Binding CreateCommand}" Content="Add"/>
                    <Button Classes="tool" Command="{Binding DuplicateCommand}" Content="Copy"/>
                    <Button Classes="delete" Command="{Binding DeleteCommand}" Content="Delete"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right panel: editor -->
        <Grid Grid.Column="2" Margin="0,8,8,8">

            <Border Classes="card" IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TransitioningContentControl Content="{Binding CurrentEditor}">
                    <TransitioningContentControl.DataTemplates>
                        <DataTemplate DataType="{x:Type vm:TestScenarioEditorViewModel}">
                            <views:TestScenarioEditorView/>
                        </DataTemplate>
                    </TransitioningContentControl.DataTemplates>
                </TransitioningContentControl>
            </Border>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                        IsVisible="{Binding CurrentEditor, Converter={x:Static ObjectConverters.IsNull}}">
                <TextBlock Text="Select or create a scenario"
                           FontSize="20" FontWeight="Light"
                           Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Use the Add button to create a new scenario"
                           FontSize="13" Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Border Background="#22C55E" CornerRadius="6" Padding="14,10"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="20"
                    IsVisible="{Binding NotificationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding NotificationMessage}" Foreground="White" FontWeight="Bold"/>
            </Border>
        </Grid>
    </Grid>
</rxui:ReactiveUserControl>
