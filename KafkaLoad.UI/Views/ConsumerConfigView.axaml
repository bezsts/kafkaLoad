<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.UI.ViewModels"
             xmlns:views="using:KafkaLoad.UI.Views"
             xmlns:enums="using:KafkaLoad.Core.Enums"
             xmlns:behaviors="using:KafkaLoad.UI.Behaviors"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="KafkaLoad.UI.Views.ConsumerConfigView"
             x:DataType="vm:ConsumerConfigViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Border.section-card">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
        <Style Selector="Button.field-reset">
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>
        <Style Selector="Grid.label-row TextBlock.field-label">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Spacing="10" Margin="20">

            <!-- Name + Group ID -->
            <Grid ColumnDefinitions="*, 16, *">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="CONFIG NAME" Classes="field-label"/>
                    <TextBox Text="{Binding Name}"
                             Watermark="e.g. local-consumer"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="GROUP ID" Classes="field-label"/>
                    <TextBox Text="{Binding GroupId}"
                             Watermark="e.g. kafkaload-group-1"/>
                </StackPanel>
            </Grid>

            <!-- Offset + Fetch settings side by side -->
            <Grid ColumnDefinitions="*, 10, *">

                <!-- Offset -->
                <Border Grid.Column="0" Classes="section-card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Consumer Settings" Classes="section-title"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="AUTO OFFSET RESET" Classes="field-label"/>
                            <WrapPanel Orientation="Horizontal">
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsOffsetLatest, Mode=OneWay}"
                                              Command="{Binding SetAutoOffsetResetCommand}"
                                              CommandParameter="{x:Static enums:AutoOffsetResetEnum.Latest}"
                                              Content="Latest"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsOffsetEarliest, Mode=OneWay}"
                                              Command="{Binding SetAutoOffsetResetCommand}"
                                              CommandParameter="{x:Static enums:AutoOffsetResetEnum.Earliest}"
                                              Content="Earliest"/>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <Grid Classes="label-row" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="MAX POLL INTERVAL (MS)" Classes="field-label"/>
                                <Button Grid.Column="1" Content="↺" Classes="field-reset"
                                        ToolTip.Tip="Reset to default" Command="{Binding ResetMaxPollIntervalCommand}"/>
                            </Grid>
                            <NumericUpDown Value="{Binding MaxPollInterval, TargetNullValue={x:Null}}"
                                           Minimum="6000" Maximum="3600000" Increment="1000"
                                           FormatString="N0"
                                           behaviors:NumericSpaceSeparatorBehavior.IsEnabled="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Fetch settings -->
                <Border Grid.Column="2" Classes="section-card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Fetch Settings" Classes="section-title"/>

                        <StackPanel Spacing="4">
                            <Grid Classes="label-row" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="FETCH MIN BYTES" Classes="field-label"/>
                                <Button Grid.Column="1" Content="↺" Classes="field-reset"
                                        ToolTip.Tip="Reset to default" Command="{Binding ResetFetchMinBytesCommand}"/>
                            </Grid>
                            <NumericUpDown Value="{Binding FetchMinBytes, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="52428800" Increment="4096" FormatString="N0"
                                           behaviors:NumericSpaceSeparatorBehavior.IsEnabled="True"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <Grid Classes="label-row" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="FETCH MAX BYTES" Classes="field-label"/>
                                <Button Grid.Column="1" Content="↺" Classes="field-reset"
                                        ToolTip.Tip="Reset to default" Command="{Binding ResetFetchMaxBytesCommand}"/>
                            </Grid>
                            <NumericUpDown Value="{Binding FetchMaxBytes, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="52428800" Increment="4096" FormatString="N0"
                                           behaviors:NumericSpaceSeparatorBehavior.IsEnabled="True"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <Grid Classes="label-row" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Text="FETCH MAX WAIT (MS)" Classes="field-label"/>
                                <Button Grid.Column="1" Content="↺" Classes="field-reset"
                                        ToolTip.Tip="Reset to default" Command="{Binding ResetFetchMaxWaitCommand}"/>
                            </Grid>
                            <NumericUpDown Value="{Binding FetchMaxWait, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="10000" Increment="5"
                                           FormatString="N0"
                                           behaviors:NumericSpaceSeparatorBehavior.IsEnabled="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Security settings (full width) -->
            <Border Classes="section-card">
                <StackPanel Spacing="10">
                    <TextBlock Text="Security Settings" Classes="section-title"/>
                    <views:SecurityConfigView DataContext="{Binding SecurityVM}"/>
                </StackPanel>
            </Border>

            <StackPanel HorizontalAlignment="Right" Spacing="6">
                <TextBlock Text="{Binding ValidationSummary}"
                           Foreground="#E53E3E"
                           FontSize="12"
                           TextWrapping="Wrap"
                           MaxWidth="520"
                           HorizontalAlignment="Right"
                           IsVisible="{Binding ValidationSummary,
                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <Button Command="{Binding SaveCommand}"
                        Content="Save Configuration"
                        Classes="accent"
                        HorizontalAlignment="Right"
                        Padding="24,10"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</rxui:ReactiveUserControl>
