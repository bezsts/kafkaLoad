<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.UI.ViewModels"
             xmlns:conv="using:KafkaLoad.UI.Helpers"
             xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="KafkaLoad.UI.Views.TestRunnerView"
             x:DataType="vm:TestRunnerViewModel">

    <UserControl.Resources>
        <conv:BytesToMegabytesConverter x:Key="BytesToMegabytesConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock.metric-label">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.metric-value">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.metric-success">
            <Setter Property="Foreground" Value="#16A34A"/>
        </Style>
        <Style Selector="TextBlock.metric-warn">
            <Setter Property="Foreground" Value="#D97706"/>
        </Style>
        <Style Selector="TextBlock.metric-error">
            <Setter Property="Foreground" Value="{DynamicResource DangerRed}"/>
        </Style>
        <Style Selector="TextBlock.field-label">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Border.section">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="260, 12, *" Margin="15">

        <!-- LEFT PANEL: Controls -->
        <Border Grid.Column="0" Classes="card" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="0" Margin="16,16,16,16">

                    <!-- Scenario selector -->
                    <StackPanel Spacing="4" Margin="0,0,0,12">
                        <TextBlock Text="TEST SCENARIO" Classes="field-label"/>
                        <ComboBox ItemsSource="{Binding TestScenarios}"
                                  SelectedItem="{Binding SelectedTestScenario}"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="Select scenario...">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="⚠ Missing producer or consumer config — edit the scenario to fix it."
                                   FontSize="11" Foreground="#EF4444" TextWrapping="Wrap"
                                   IsVisible="{Binding SelectedTestScenario.IsConfigValid, FallbackValue=False, TargetNullValue=False, Converter={x:Static BoolConverters.Not}}"/>
                    </StackPanel>

                    <Separator Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,12"/>

                    <!-- Bootstrap Servers -->
                    <StackPanel Spacing="4" Margin="0,0,0,10">
                        <TextBlock Text="BOOTSTRAP SERVERS" Classes="field-label"/>
                        <TextBox Text="{Binding BootstrapServers}"
                                 Watermark="localhost:9092"
                                 FontSize="13"/>
                    </StackPanel>

                    <!-- Topic -->
                    <StackPanel Spacing="4" Margin="0,0,0,12">
                        <TextBlock Text="TOPIC" Classes="field-label"/>
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0" Text="{Binding TopicName}"
                                     Watermark="my-topic"
                                     FontSize="13"/>
                            <Button Grid.Column="1" Command="{Binding RefreshTopicCommand}"
                                    ToolTip.Tip="Check topic availability"
                                    Background="Transparent" Padding="6,4" BorderThickness="1"
                                    BorderBrush="{DynamicResource BorderColor}" CornerRadius="4">
                                <TextBlock Text="↻" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBlue}"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Topic status -->
                    <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                        <Border.Styles>
                            <Style Selector="Border[Tag=True]">
                                <Setter Property="Background" Value="#F0FDF4"/>
                                <Setter Property="BorderBrush" Value="#86EFAC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                            <Style Selector="Border[Tag=False]">
                                <Setter Property="Background" Value="#FFF1F2"/>
                                <Setter Property="BorderBrush" Value="#FECDD3"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                            <Style Selector="Border">
                                <Setter Property="Background" Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                        </Border.Styles>
                        <Border.Tag>
                            <Binding Path="IsTopicFound"/>
                        </Border.Tag>
                        <TextBlock Text="{Binding TopicDisplayInfo}" FontSize="12" FontWeight="SemiBold">
                            <TextBlock.Styles>
                                <Style Selector="TextBlock[Tag=True]">
                                    <Setter Property="Foreground" Value="#16A34A"/>
                                </Style>
                                <Style Selector="TextBlock[Tag=False]">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerRed}"/>
                                </Style>
                                <Style Selector="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                </Style>
                            </TextBlock.Styles>
                            <TextBlock.Tag>
                                <Binding Path="IsTopicFound"/>
                            </TextBlock.Tag>
                        </TextBlock>
                    </Border>

                    <Separator Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,12"/>

                    <!-- Status -->
                    <StackPanel Spacing="4" Margin="0,0,0,16">
                        <TextBlock Text="STATUS" Classes="field-label"/>
                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"
                                   FontSize="13" Foreground="{DynamicResource PrimaryBlue}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Run / Stop buttons -->
                    <Grid ColumnDefinitions="*, 8, *">
                        <Button Grid.Column="0" Command="{Binding StartTestCommand}"
                                Content="▶  Run"
                                Background="#10B981" Foreground="White"
                                FontWeight="Bold" FontSize="14"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Padding="0,10" CornerRadius="6"/>
                        <Button Grid.Column="2" Command="{Binding StopTestCommand}"
                                Content="⏹  Stop"
                                Classes="delete"
                                FontWeight="Bold" FontSize="14"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Padding="0,10" CornerRadius="6"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- RIGHT PANEL: Metrics -->
        <Grid Grid.Column="2">

            <!-- Placeholder when no metrics -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10"
                        IsVisible="{Binding Metrics, Converter={x:Static ObjectConverters.IsNull}}">
                <TextBlock Text="No active test" FontSize="22" FontWeight="Light"
                           Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                <TextBlock Text="Select a scenario, enter connection details and press Run"
                           FontSize="14" Foreground="{DynamicResource TextSecondary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding Metrics, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Grid ColumnDefinitions="*, 12, *">

                    <!-- Producer Metrics Card -->
                    <Border Grid.Column="0" Classes="card" Padding="16">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="4" Height="20" Background="{DynamicResource PrimaryBlue}" CornerRadius="2"/>
                                <TextBlock Text="Producer Metrics" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Separator Height="1" Background="{DynamicResource BorderColor}"/>

                            <Grid ColumnDefinitions="*, 8, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="metric-label" Text="Attempted"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Classes="metric-value"
                                           Text="{Binding Metrics.Producer.TotalMessagesAttempted, StringFormat='{}{0:N0}', FallbackValue='0'}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="metric-label" Text="Sent"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Classes="metric-value metric-success"
                                           Text="{Binding Metrics.Producer.SuccessMessagesSent, StringFormat='{}{0:N0}', FallbackValue='0'}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="metric-label" Text="Errors"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Classes="metric-value metric-error"
                                           Text="{Binding Metrics.Producer.TotalErrors, StringFormat='{}{0:N0}', FallbackValue='0'}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Classes="metric-label" Text="Throughput"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Classes="metric-value"
                                           Text="{Binding Metrics.Producer.ThroughputMsgSec, StringFormat='{}{0:N1} msg/s', FallbackValue='0.0 msg/s'}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Classes="metric-label" Text="Data sent"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Classes="metric-value"
                                           Text="{Binding Metrics.Producer.ThroughputBytesSec, Converter={StaticResource BytesToMegabytesConverter}, StringFormat='{}{0:N2} MB/s', FallbackValue='0.00 MB/s'}"/>
                            </Grid>

                            <Grid ColumnDefinitions="*, 8, *" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="metric-label" Text="P50 latency"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Classes="metric-value metric-warn"
                                           Text="{Binding Metrics.Producer.P50Lat, StringFormat='{}{0:N2} ms', FallbackValue='0.00 ms'}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="metric-label" Text="P95 latency"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Classes="metric-value metric-warn"
                                           Text="{Binding Metrics.Producer.P95Lat, StringFormat='{}{0:N2} ms', FallbackValue='0.00 ms'}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="metric-label" Text="P99 latency"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Classes="metric-value metric-warn"
                                           Text="{Binding Metrics.Producer.P99Lat, StringFormat='{}{0:N2} ms', FallbackValue='0.00 ms'}"/>
                            </Grid>

                            <Separator Height="1" Background="{DynamicResource BorderColor}"/>

                            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,6">
                                <TextBlock Grid.Column="0" Text="Graph" FontWeight="SemiBold"
                                           FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox Grid.Column="1" Name="ProducerMetricSelector" SelectedIndex="0" Width="150" Height="28" FontSize="12">
                                    <ComboBoxItem>Throughput (MB/s)</ComboBoxItem>
                                    <ComboBoxItem>Throughput (Msg/s)</ComboBoxItem>
                                    <ComboBoxItem>Latency (ms)</ComboBoxItem>
                                    <ComboBoxItem>Errors</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <Border Height="180" CornerRadius="4" ClipToBounds="True"
                                    Background="#F9FAFB" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                <sp:AvaPlot Name="ProducerChart"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Consumer Metrics Card -->
                    <Border Grid.Column="2" Classes="card" Padding="16">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="4" Height="20" Background="#10B981" CornerRadius="2"/>
                                <TextBlock Text="Consumer Metrics" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Separator Height="1" Background="{DynamicResource BorderColor}"/>

                            <Grid ColumnDefinitions="*, 8, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="metric-label" Text="Received"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Classes="metric-value"
                                           Text="{Binding Metrics.Consumer.TotalMessagesConsumed, StringFormat='{}{0:N0}', FallbackValue='0'}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="metric-label" Text="Successful"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Classes="metric-value metric-success"
                                           Text="{Binding Metrics.Consumer.SuccessMessagesConsumed, StringFormat='{}{0:N0}', FallbackValue='0'}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="metric-label" Text="Errors"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Classes="metric-value metric-error"
                                           Text="{Binding Metrics.Consumer.ErrorMessagesConsumed, StringFormat='{}{0:N0}', FallbackValue='0'}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Classes="metric-label" Text="Throughput"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Classes="metric-value"
                                           Text="{Binding Metrics.Consumer.ThroughputMsgSec, StringFormat='{}{0:N1} msg/s', FallbackValue='0.0 msg/s'}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Classes="metric-label" Text="Data recv"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Classes="metric-value"
                                           Text="{Binding Metrics.Consumer.ThroughputBytesSec, Converter={StaticResource BytesToMegabytesConverter}, StringFormat='{}{0:N2} MB/s', FallbackValue='0.00 MB/s'}"/>
                            </Grid>

                            <Grid ColumnDefinitions="*, 8, *" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="metric-label" Text="P50 E2E latency"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Classes="metric-value metric-warn"
                                           Text="{Binding Metrics.Consumer.P50Lat, StringFormat='{}{0:N2} ms', FallbackValue='0.00 ms'}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="metric-label" Text="P95 E2E latency"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Classes="metric-value metric-warn"
                                           Text="{Binding Metrics.Consumer.P95Lat, StringFormat='{}{0:N2} ms', FallbackValue='0.00 ms'}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="metric-label" Text="P99 E2E latency"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Classes="metric-value metric-warn"
                                           Text="{Binding Metrics.Consumer.P99Lat, StringFormat='{}{0:N2} ms', FallbackValue='0.00 ms'}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Classes="metric-label" Text="Consumer lag"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Classes="metric-value"
                                           Text="{Binding Metrics.Consumer.FinalConsumerLag, StringFormat='{}{0:N0}', FallbackValue='0'}"/>
                            </Grid>

                            <Separator Height="1" Background="{DynamicResource BorderColor}"/>

                            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,6">
                                <TextBlock Grid.Column="0" Text="Graph" FontWeight="SemiBold"
                                           FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox Grid.Column="1" Name="ConsumerMetricSelector" SelectedIndex="0" Width="150" Height="28" FontSize="12">
                                    <ComboBoxItem>Throughput (MB/s)</ComboBoxItem>
                                    <ComboBoxItem>Throughput (Msg/s)</ComboBoxItem>
                                    <ComboBoxItem>Latency (ms)</ComboBoxItem>
                                    <ComboBoxItem>Errors</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <Border Height="180" CornerRadius="4" ClipToBounds="True"
                                    Background="#F9FAFB" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                <sp:AvaPlot Name="ConsumerChart"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </Grid>
            </ScrollViewer>
        </Grid>

    </Grid>
</rxui:ReactiveUserControl>
