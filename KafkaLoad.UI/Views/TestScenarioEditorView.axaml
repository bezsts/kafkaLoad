<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.UI.ViewModels"
             xmlns:enums="using:KafkaLoad.Core.Enums"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="KafkaLoad.UI.Views.TestScenarioEditorView"
             x:DataType="vm:TestScenarioEditorViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="Border.section-card">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="20">

            <!-- Row 1: Name -->
            <StackPanel Spacing="4">
                <TextBlock Text="SCENARIO NAME" Classes="field-label"/>
                <TextBox Text="{Binding Name}"
                         FontSize="14" FontWeight="SemiBold"
                         Watermark="e.g. High Load Test"/>
            </StackPanel>

            <!-- Row 2: Test Type buttons -->
            <StackPanel Spacing="4">
                <TextBlock Text="TEST TYPE" Classes="field-label"/>
                <WrapPanel Orientation="Horizontal">
                    <ToggleButton Classes="filter" Margin="0,0,4,4"
                                  IsChecked="{Binding IsTypeLoad, Mode=OneWay}"
                                  Command="{Binding SetTestTypeCommand}"
                                  CommandParameter="{x:Static enums:TestType.Load}"
                                  Content="Load"/>
                    <ToggleButton Classes="filter" Margin="0,0,4,4"
                                  IsChecked="{Binding IsTypeStress, Mode=OneWay}"
                                  Command="{Binding SetTestTypeCommand}"
                                  CommandParameter="{x:Static enums:TestType.Stress}"
                                  Content="Stress"/>
                    <ToggleButton Classes="filter" Margin="0,0,4,4"
                                  IsChecked="{Binding IsTypeSpike, Mode=OneWay}"
                                  Command="{Binding SetTestTypeCommand}"
                                  CommandParameter="{x:Static enums:TestType.Spike}"
                                  Content="Spike"/>
                    <ToggleButton Classes="filter" Margin="0,0,4,4"
                                  IsChecked="{Binding IsTypeSoak, Mode=OneWay}"
                                  Command="{Binding SetTestTypeCommand}"
                                  CommandParameter="{x:Static enums:TestType.Soak}"
                                  Content="Soak"/>
                </WrapPanel>
            </StackPanel>

            <!-- Row 2: Clients Config (left) + Data Generation (right) side by side -->
            <Grid ColumnDefinitions="*, 10, *">

                <!-- Clients Configuration -->
                <Border Grid.Column="0" Classes="section-card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Clients Configuration" Classes="section-title"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="PRODUCER CONFIG" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding Producers}"
                                      SelectedItem="{Binding SelectedProducer}"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="Select producer...">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="CONSUMER CONFIG" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding Consumers}"
                                      SelectedItem="{Binding SelectedConsumer}"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="Select consumer...">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Data Generation -->
                <Border Grid.Column="2" Classes="section-card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Data Generation" Classes="section-title"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="KEY STRATEGY" Classes="field-label"/>
                            <WrapPanel Orientation="Horizontal">
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsKeyNull, Mode=OneWay}"
                                              Command="{Binding SetKeyStrategyCommand}"
                                              CommandParameter="{x:Static enums:KeyGenerationStrategy.Null}"
                                              Content="Null"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsKeyRandomInt, Mode=OneWay}"
                                              Command="{Binding SetKeyStrategyCommand}"
                                              CommandParameter="{x:Static enums:KeyGenerationStrategy.RandomInt}"
                                              Content="Random Int"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsKeySequential, Mode=OneWay}"
                                              Command="{Binding SetKeyStrategyCommand}"
                                              CommandParameter="{x:Static enums:KeyGenerationStrategy.SequentialInt}"
                                              Content="Sequential"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsKeyRandomStr, Mode=OneWay}"
                                              Command="{Binding SetKeyStrategyCommand}"
                                              CommandParameter="{x:Static enums:KeyGenerationStrategy.RandomString}"
                                              Content="Random String"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsKeyFixed, Mode=OneWay}"
                                              Command="{Binding SetKeyStrategyCommand}"
                                              CommandParameter="{x:Static enums:KeyGenerationStrategy.Fixed}"
                                              Content="Fixed"/>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="VALUE STRATEGY" Classes="field-label"/>
                            <WrapPanel Orientation="Horizontal">
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsValueRandomStr, Mode=OneWay}"
                                              Command="{Binding SetValueStrategyCommand}"
                                              CommandParameter="{x:Static enums:ValueGenerationStrategy.RandomString}"
                                              Content="Random String"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsValueJson, Mode=OneWay}"
                                              Command="{Binding SetValueStrategyCommand}"
                                              CommandParameter="{x:Static enums:ValueGenerationStrategy.Json}"
                                              Content="Json"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsValueAvro, Mode=OneWay}"
                                              Command="{Binding SetValueStrategyCommand}"
                                              CommandParameter="{x:Static enums:ValueGenerationStrategy.Avro}"
                                              Content="Avro"/>
                                <ToggleButton Classes="filter" Margin="0,0,4,4"
                                              IsChecked="{Binding IsValueProtobuf, Mode=OneWay}"
                                              Command="{Binding SetValueStrategyCommand}"
                                              CommandParameter="{x:Static enums:ValueGenerationStrategy.Protobuf}"
                                              Content="Protobuf"/>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Spacing="4" IsVisible="{Binding IsFixedKeyVisible}">
                            <TextBlock Text="FIXED KEY" Classes="field-label"/>
                            <TextBox Text="{Binding FixedKey}"
                                     Watermark="e.g. my-fixed-key"/>
                        </StackPanel>

                        <StackPanel Spacing="4" IsVisible="{Binding IsMessageSizeVisible}">
                            <TextBlock Text="MESSAGE SIZE (BYTES)" Classes="field-label"/>
                            <NumericUpDown Value="{Binding MessageSize, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="10485760" Increment="128" FormatString="N0"/>
                        </StackPanel>

                        <StackPanel Spacing="4" IsVisible="{Binding IsJsonTemplateVisible}">
                            <TextBlock Text="JSON TEMPLATE" Classes="field-label"/>
                            <TextBox Text="{Binding FixedTemplate}"
                                     AcceptsReturn="True"
                                     MinHeight="90"
                                     TextWrapping="Wrap"
                                     FontFamily="Cascadia Code, Consolas, Monospace"
                                     Watermark="{}{&quot;id&quot;: &quot;${uuid}&quot;, &quot;amount&quot;: &quot;${randomInt:1:1000}&quot;}"/>
                            <TextBlock Text="Placeholders: ${uuid}  ${randomInt:min:max}  ${randomString:N}  ${timestamp}  ${randomBool}"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Spacing="4" IsVisible="{Binding IsAvroSchemaVisible}">
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="AVRO SCHEMA" Classes="field-label" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <Button Content="Import File"
                                        DockPanel.Dock="Right"
                                        Command="{Binding ImportAvroSchemaCommand}"
                                        Padding="8,2"
                                        FontSize="11"/>
                            </DockPanel>
                            <TextBox Text="{Binding FixedTemplate}"
                                     AcceptsReturn="True"
                                     MinHeight="90"
                                     TextWrapping="Wrap"
                                     FontFamily="Cascadia Code, Consolas, Monospace"
                                     Watermark="{}{&quot;type&quot;:&quot;record&quot;,&quot;name&quot;:&quot;Event&quot;,&quot;fields&quot;:[{&quot;name&quot;:&quot;id&quot;,&quot;type&quot;:&quot;string&quot;}]}"/>
                            <TextBlock Text="Supported field types: string, int, long, float, double, boolean, null, union"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Spacing="4" IsVisible="{Binding IsProtobufSchemaVisible}">
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="PROTOBUF SCHEMA (.proto)" Classes="field-label" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <Button Content="Import File"
                                        DockPanel.Dock="Right"
                                        Command="{Binding ImportProtobufSchemaCommand}"
                                        Padding="8,2"
                                        FontSize="11"/>
                            </DockPanel>
                            <TextBox Text="{Binding FixedTemplate}"
                                     AcceptsReturn="True"
                                     MinHeight="90"
                                     TextWrapping="Wrap"
                                     FontFamily="Cascadia Code, Consolas, Monospace"
                                     Watermark="{}syntax = &quot;proto3&quot;;&#10;message Event &#123;&#10;  string id = 1;&#10;  int32 amount = 2;&#10;&#125;"/>
                            <TextBlock Text="Supported field types: string, int32, int64, uint32, uint64, float, double, bool, bytes, enum"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 3: Load Parameters (full width) -->
            <Border Classes="section-card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Load Parameters" Classes="section-title"/>

                    <!-- Row 1: Duration | Target Throughput (Load/Stress/Soak) -->
                    <Grid ColumnDefinitions="*, 10, *">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="DURATION (SEC)" Classes="field-label"/>
                            <NumericUpDown Value="{Binding Duration, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="86400" Increment="10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4" IsVisible="{Binding IsTargetThroughputVisible}">
                            <TextBlock Text="TARGET THROUGHPUT (MSG/SEC)" Classes="field-label"/>
                            <NumericUpDown Value="{Binding TargetThroughput, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="10000000" Increment="100" FormatString="N0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Producers | Consumers -->
                    <Grid ColumnDefinitions="*, 10, *">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="PRODUCERS" Classes="field-label"/>
                            <NumericUpDown Value="{Binding ProducerCount, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="100" Increment="1" FormatString="N0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="CONSUMERS" Classes="field-label"/>
                            <NumericUpDown Value="{Binding ConsumerCount, TargetNullValue={x:Null}}"
                                           Minimum="0" Maximum="100" Increment="1" FormatString="N0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row 3: Base Throughput | Spike Throughput (Spike only) -->
                    <Grid ColumnDefinitions="*, 10, *" IsVisible="{Binding IsSpikeVisible}">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="BASE THROUGHPUT (MSG/SEC)" Classes="field-label"/>
                            <NumericUpDown Value="{Binding BaseThroughput, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="10000000" Increment="100" FormatString="N0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="SPIKE THROUGHPUT (MSG/SEC)" Classes="field-label"/>
                            <NumericUpDown Value="{Binding SpikeThroughput, TargetNullValue={x:Null}}"
                                           Minimum="1" Maximum="10000000" Increment="1000" FormatString="N0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Button Command="{Binding SaveCommand}"
                    Content="Save Scenario"
                    Classes="accent"
                    HorizontalAlignment="Right"
                    Padding="24,10"/>
        </StackPanel>
    </ScrollViewer>
</rxui:ReactiveUserControl>
