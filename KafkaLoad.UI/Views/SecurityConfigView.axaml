<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:KafkaLoad.UI.ViewModels.Clients"
             xmlns:enums="using:KafkaLoad.UI.Enums"
             x:DataType="vm:SecurityConfigViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="KafkaLoad.UI.Views.SecurityConfigView">
  <StackPanel Spacing="10">
        <TextBlock Text="Security Protocol" Classes="label"/>
        <ComboBox ItemsSource="{Binding SecurityProtocolOptions}" 
                  SelectedItem="{Binding SecurityProtocol}" 
                  HorizontalAlignment="Stretch"/>

        <StackPanel Spacing="10" IsVisible="{Binding IsSaslVisible}" Margin="0,10,0,0">
            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,10,0,0"/>
            <TextBlock Text="SASL Authentication" FontWeight="Bold" Foreground="{DynamicResource PrimaryBlue}"/>
            
            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" RowSpacing="10" ColumnSpacing="15">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
                    <TextBlock Text="SASL Mechanism" Classes="label"/>
                    <ComboBox ItemsSource="{Binding SaslMechanismOptions}" SelectedItem="{Binding SaslMechanism}" HorizontalAlignment="Stretch"/>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Username" Classes="label"/>
                    <TextBox Text="{Binding SaslUsername}" Watermark="Enter username"/>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="5">
                    <TextBlock Text="Password" Classes="label"/>
                    <TextBox Text="{Binding SaslPassword}" PasswordChar="*" Watermark="Enter password"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Spacing="10" IsVisible="{Binding IsSslCaVisible}" Margin="0,10,0,0">
            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,10,0,0"/>
            <TextBlock Text="SSL Encryption / Certificates" FontWeight="Bold" Foreground="{DynamicResource PrimaryBlue}"/>

            <TextBlock Text="CA Certificate Location (PEM)" Classes="label"/>
            <Grid ColumnDefinitions="*, Auto">
                <TextBox Grid.Column="0" Text="{Binding SslCaLocation}" Watermark="/path/to/ca.pem"/>
                <Button Grid.Column="1" x:Name="BrowseCaBtn" Content="Browse" Margin="5,0,0,0" Classes="tool"/>
            </Grid>

            <StackPanel Spacing="10" IsVisible="{Binding IsClientCertVisible}" Margin="0,5,0,0">
                <TextBlock Text="Client Certificate Location (PEM)" Classes="label"/>
                <Grid ColumnDefinitions="*, Auto">
                    <TextBox Grid.Column="0" Text="{Binding SslCertificateLocation}" Watermark="/path/to/client.pem"/>
                    <Button Grid.Column="1" x:Name="BrowseCertBtn" Content="Browse" Margin="5,0,0,0" Classes="tool"/>
                </Grid>

                <TextBlock Text="Client Private Key Location (PEM)" Classes="label"/>
                <Grid ColumnDefinitions="*, Auto">
                    <TextBox Grid.Column="0" Text="{Binding SslKeyLocation}" Watermark="/path/to/client.key"/>
                    <Button Grid.Column="1" x:Name="BrowseKeyBtn" Content="Browse" Margin="5,0,0,0" Classes="tool"/>
                </Grid>

                <TextBlock Text="Private Key Password (Optional)" Classes="label"/>
                <TextBox Text="{Binding SslKeyPassword}" PasswordChar="*" Watermark="Key password"/>
            </StackPanel>
        </StackPanel>
        
    </StackPanel>
</UserControl>
