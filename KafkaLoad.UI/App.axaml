<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:KafkaLoad.UI"
             x:Class="KafkaLoad.UI.App"
             RequestedThemeVariant="Light">
             <Application.DataTemplates>
    </Application.DataTemplates>

    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBlue">#0078D7</SolidColorBrush>
        <SolidColorBrush x:Key="PrimaryBlueHover">#1084E3</SolidColorBrush>
        <SolidColorBrush x:Key="DangerRed">#D32F2F</SolidColorBrush>
        <SolidColorBrush x:Key="DangerRedHover">#E53935</SolidColorBrush>
        <SolidColorBrush x:Key="AppBackground">#F3F4F6</SolidColorBrush> <SolidColorBrush x:Key="CardBackground">#FFFFFF</SolidColorBrush> <SolidColorBrush x:Key="TextPrimary">#1F2937</SolidColorBrush>
        <SolidColorBrush x:Key="TextSecondary">#6B7280</SolidColorBrush>
        <SolidColorBrush x:Key="BorderColor">#E5E7EB</SolidColorBrush>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
        
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #20000000"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15,8"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryBlueHover}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.tool">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#A0A0A0"/>
        </Style>

        <Style Selector="Button.delete">
            <Setter Property="Background" Value="{DynamicResource DangerRed}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.delete:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DangerRedHover}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#E0F2FE"/> <Setter Property="Foreground" Value="{DynamicResource PrimaryBlue}"/>
        </Style>

        <!-- Search TextBox -->
        <Style Selector="TextBox.search">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="6,6,8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="InnerLeftContent">
                <Template>
                    <PathIcon Width="13" Height="13" Margin="6,0,2,0"
                              Foreground="{DynamicResource TextSecondary}"
                              Data="M 8 0 C 3.582 0 0 3.582 0 8 C 0 12.418 3.582 16 8 16 C 9.848 16 11.551 15.372 12.908 14.322 L 15.293 16.707 A 1 1 0 1 0 16.707 15.293 L 14.322 12.908 C 15.372 11.551 16 9.848 16 8 C 16 3.582 12.418 0 8 0 Z M 2 8 C 2 4.686 4.686 2 8 2 C 11.314 2 14 4.686 14 8 C 14 11.314 11.314 14 8 14 C 4.686 14 2 11.314 2 8 Z"/>
                </Template>
            </Setter>
        </Style>
        <Style Selector="TextBox.search /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="TextBox.search:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
        </Style>

        <!-- Filter chip ToggleButton -->
        <Style Selector="ToggleButton.filter">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ToggleButton.filter:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F0F9FF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
        </Style>
        <Style Selector="ToggleButton.filter:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
        </Style>
        <Style Selector="ToggleButton.filter:checked:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryBlueHover}"/>
        </Style>

        <!-- Sort ComboBox (compact) -->
        <Style Selector="ComboBox.sort">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="White"/>
        </Style>

    </Application.Styles>
</Application>