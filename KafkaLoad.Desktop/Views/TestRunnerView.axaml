<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.Desktop.ViewModels"
             xmlns:conv="using:KafkaLoad.Desktop.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="KafkaLoad.Desktop.Views.TestRunnerView"
             x:DataType="vm:TestRunnerViewModel">

    <UserControl.Resources>
        <conv:BytesToMegabytesConverter x:Key="BytesToMegabytesConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *" Margin="20">
        
        <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <TextBlock Text="Test Runner" FontSize="24" FontWeight="Bold"/>

            <StackPanel Spacing="5">
                <TextBlock Text="Select Test Scenario *" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding TestScenarios}"
                          SelectedItem="{Binding SelectedTestScenario}"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="Choose a test scenario...">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            
            <Border Background="#2D2D30" CornerRadius="5" Padding="10">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Status:" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Command="{Binding StartTestCommand}" 
                                Content="▶ START TEST" 
                                Background="Green" Foreground="White" FontWeight="Bold"/>
                        
                        <Button Command="{Binding StopTestCommand}" 
                                Content="⏹ STOP" 
                                Background="#C0392B" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*, 20, *" IsVisible="{Binding Metrics, Converter={x:Static ObjectConverters.IsNotNull}}">
            
            <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" CornerRadius="5" Padding="15" Background="#1E1E1E">
                <StackPanel Spacing="10">
                    <TextBlock Text="PRODUCER METRICS" FontSize="18" FontWeight="Bold" Foreground="#3498DB" HorizontalAlignment="Center"/>
                    <Separator/>

                    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                        <Grid.Styles>
                            <Style Selector="TextBlock.label">
                                <Setter Property="Foreground" Value="#AAA"/>
                                <Setter Property="Margin" Value="0,0,10,10"/>
                            </Style>
                            <Style Selector="TextBlock.value">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </Grid.Styles>

                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Total messages sent:"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Classes="value" Text="{Binding Metrics.Producer.TotalMsgsSent, StringFormat='N0'}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Total MB sent:"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Classes="value" Text="{Binding Metrics.Producer.TotalBytesSent, Converter={StaticResource BytesToMegabytesConverter}, StringFormat='N2 MB'}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Successful messages sent:"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Classes="value" 
                                   Text="{Binding Metrics.Producer.SuccessMsgsSent}" Foreground="#3ce742"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Errors:"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Classes="value" 
                                   Text="{Binding Metrics.Producer.ErrorMsgsSent}" Foreground="#E74C3C"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Throughput (Msg/sec):"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Classes="value" Text="{Binding Metrics.Producer.ThroughputMsg, StringFormat='N1'}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Classes="label" Text="Throughput (MB/sec):"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Classes="value" 
                                   Text="{Binding Metrics.Producer.ThroughputBytes, Converter={StaticResource BytesToMegabytesConverter}, StringFormat='N2 MB/s'}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Classes="label" Text="Avg Latency:"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Classes="value" 
                                   Text="{Binding Metrics.Producer.AvgLatMs, StringFormat='N2 ms'}" Foreground="#F1C40F"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" BorderBrush="#444" BorderThickness="1" CornerRadius="5" Padding="15" Background="#1E1E1E">
                <StackPanel Spacing="10">
                    <TextBlock Text="CONSUMER METRICS" FontSize="18" FontWeight="Bold" Foreground="#2ECC71" HorizontalAlignment="Center"/>
                    <Separator/>

                    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                        <Grid.Styles>
                            <Style Selector="TextBlock.label">
                                <Setter Property="Foreground" Value="#AAA"/>
                                <Setter Property="Margin" Value="0,0,10,10"/>
                            </Style>
                            <Style Selector="TextBlock.value">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </Grid.Styles>

                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Total messages received:"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Classes="value" Text="{Binding Metrics.Consumer.TotalMsgConsumed, StringFormat='N0'}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Total MB received:"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Classes="value" Text="{Binding Metrics.Consumer.TotalBytesConsumed, Converter={StaticResource BytesToMegabytesConverter}, StringFormat='N2 MB'}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Successful messages received:"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Classes="value" 
                                   Text="{Binding Metrics.Consumer.SuccessMsgsConsumed}" Foreground="#3ce742"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Errors:"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Classes="value" 
                                   Text="{Binding Metrics.Consumer.ErrorMsgsConsumed}" Foreground="#E74C3C"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Throughput (Msg/sec):"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Classes="value" Text="{Binding Metrics.Consumer.ThroughputMsg, StringFormat='N1'}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Classes="label" Text="Throughput (MB/sec):"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Classes="value" 
                                   Text="{Binding Metrics.Consumer.ThroughputBytes, Converter={StaticResource BytesToMegabytesConverter}, StringFormat='N2 MB/s'}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Classes="label" Text="E2E Latency:"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Classes="value" 
                                   Text="{Binding Metrics.Consumer.AvgLatencyMs, StringFormat='N2 ms'}" Foreground="#F1C40F"/>
                    </Grid>
                </StackPanel>
            </Border>

        </Grid>
        
        <TextBlock Grid.Row="1" Text="Waiting for test start..." 
                   HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"
                   IsVisible="{Binding Metrics, Converter={x:Static ObjectConverters.IsNull}}"/>
    </Grid>
</rxui:ReactiveUserControl>
