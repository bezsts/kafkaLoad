<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:KafkaLoad.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="KafkaLoad.Desktop.Views.ProducerConfigurationView"
             x:DataType="vm:ProducerConfigurationViewModel">
  <ScrollViewer>
        <StackPanel Spacing="15" Margin="20">
            
            <TextBlock Text="Producer Configuration" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

            <StackPanel Spacing="5">
                <TextBlock Text="Configuration Name *" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Name}" Watermark="e.g. Prod-HighThroughput"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Bootstrap Servers *" FontWeight="SemiBold"/>
                <TextBox Text="{Binding BootstrapServers}" Watermark="e.g. localhost:9092, 192.168.1.5:9092"/>
            </StackPanel>

            <Separator Height="20" Opacity="0"/> <Grid ColumnDefinitions="*, 10, *">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="Key Serializer"/>
                    <ComboBox ItemsSource="{Binding KeySerializerOptions}"
                              SelectedItem="{Binding SelectedKeySerializer}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="5">
                    <TextBlock Text="Value Serializer"/>
                    <ComboBox ItemsSource="{Binding ValueSerializerOptions}"
                              SelectedItem="{Binding SelectedValueSerializer}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="5">
                <TextBlock Text="Acks (Durability)"/>
                <ComboBox ItemsSource="{Binding AcksOptions}"
                          SelectedItem="{Binding SelectedAcks}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>

            <CheckBox IsChecked="{Binding EnableIdempotence}" 
                      Content="Enable Idempotence (Strict Order, No Duplicates)"/>

            <Grid ColumnDefinitions="*, 15, *" RowDefinitions="Auto, Auto, Auto, Auto">
                
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Batch Size (Bytes)"/>
                    <NumericUpDown Value="{Binding BatchSize}" 
                                   Minimum="0" Maximum="52428800" Increment="4096"
                                   FormatString="N0"/> </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="5">
                    <TextBlock Text="Linger (ms)"/>
                    <NumericUpDown Value="{Binding Linger}" 
                                   Minimum="0" Maximum="10000" Increment="5"/>
                </StackPanel>

                <Border Grid.Row="1" Height="15"/>

                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Buffer Memory (Bytes)"/>
                    <NumericUpDown Value="{Binding BufferMemory}" 
                                   Minimum="0" Increment="1048576" 
                                   FormatString="N0"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" Spacing="5">
                    <TextBlock Text="Retries"/>
                    <NumericUpDown Value="{Binding Retries}" 
                                   Minimum="0" Increment="1"/>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="5">
                <TextBlock Text="Max In-Flight Requests"/>
                <NumericUpDown Value="{Binding MaxInFlightRequestsPerConnection}" 
                               Minimum="1" Maximum="100" Increment="1"
                               Watermark="Default: 5"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Compression Type"/>
                <ComboBox ItemsSource="{Binding CompressionTypeOptions}"
                          SelectedItem="{Binding SelectedCompressionType}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>

            <Button Command="{Binding SaveCommand}" 
                    Content="Save Configuration"
                    Classes="accent" 
                    HorizontalAlignment="Right"
                    Padding="20, 10"
                    Margin="0,20,0,0"/>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
