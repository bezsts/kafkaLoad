<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:KafkaLoad.Desktop.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="KafkaLoad.Desktop.MainWindow"
        Title="KafkaLoad.Desktop">
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <TabControl Margin="5">
        
        <TabItem Header="Run Load Test" FontSize="16">
            <Grid ColumnDefinitions="350, *" Margin="10">
                <StackPanel Grid.Column="0" Spacing="15">
                    <TextBlock Text="Scenario Settings" FontWeight="Bold" FontSize="18"/>

                    <StackPanel>
                        <TextBlock Text="Select Producer Config"/>
                        <ComboBox ItemsSource="{Binding ProducerProfiles}" 
                                  SelectedItem="{Binding SelectedProducerProfile}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Select Consumer Config"/>
                        <ComboBox ItemsSource="{Binding ConsumerProfiles}" 
                                  SelectedItem="{Binding SelectedConsumerProfile}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <Separator/>

                    <StackPanel>
                        <TextBlock Text="Topic Name"/>
                        <TextBox Text="{Binding TopicName}"/>
                    </StackPanel>
                    
                    <StackPanel>
                        <TextBlock Text="Threads (Producers)"/>
                        <NumericUpDown Value="{Binding Threads}" Minimum="1" Maximum="100"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Message Size (bytes)"/>
                        <NumericUpDown Value="{Binding MessageSize}" Increment="128"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Duration (seconds)"/>
                        <NumericUpDown Value="{Binding Duration}"/>
                    </StackPanel>

                    <Button Command="{Binding StartTestCommand}" 
                            Content="START TEST" 
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="#007ACC" Foreground="White" FontWeight="Bold" Padding="10"/>
                </StackPanel>

                <Border Grid.Column="1" Margin="20,0,0,0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                    <TextBox Text="{Binding Logs}" IsReadOnly="True" BorderThickness="0" Background="Black" Foreground="#00FF00" FontFamily="Consolas"/>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="Manage Profiles" FontSize="16">
            <Grid ColumnDefinitions="250, *" Margin="10">
                
                <DockPanel Grid.Column="0" LastChildFill="True">
                    <Button DockPanel.Dock="Bottom" Content="+ Add New Profile" Command="{Binding AddNewProducerProfileCommand}" HorizontalAlignment="Stretch"/>
                    <ListBox ItemsSource="{Binding ProducerProfiles}" SelectedItem="{Binding EditingProducerProfile}" Background="#F0F0F0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <ScrollViewer Grid.Column="1" Margin="20,0,0,0">
                    <StackPanel Spacing="10" IsVisible="{Binding EditingProducerProfile, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Text="Edit Producer Profile" FontWeight="Bold" FontSize="20"/>
                        
                        <TextBlock Text="Profile Name"/>
                        <TextBox Text="{Binding EditingProducerProfile.Name}"/>

                        <TextBlock Text="Bootstrap Servers"/>
                        <TextBox Text="{Binding EditingProducerProfile.BootstrapServers}"/>

                        <TextBlock Text="Acks (Reliability)"/>
                        <ComboBox SelectedIndex="{Binding EditingProducerProfile.Acks, Mode=TwoWay}" HorizontalAlignment="Stretch">
                            <ComboBoxItem>Leader (1)</ComboBoxItem>
                            <ComboBoxItem>All (-1)</ComboBoxItem>
                            <ComboBoxItem>None (0)</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Batch Size (bytes)"/>
                        <NumericUpDown Value="{Binding EditingProducerProfile.BatchSize}"/>

                        <TextBlock Text="Linger MS (wait time)"/>
                        <NumericUpDown Value="{Binding EditingProducerProfile.LingerMs}"/>

                        <TextBlock Text="Compression"/>
                        <ComboBox SelectedIndex="{Binding EditingProducerProfile.Compression, Mode=TwoWay}" HorizontalAlignment="Stretch">
                            <ComboBoxItem>None</ComboBoxItem>
                            <ComboBoxItem>Gzip</ComboBoxItem>
                            <ComboBoxItem>Snappy</ComboBoxItem>
                            <ComboBoxItem>Lz4</ComboBoxItem>
                            <ComboBoxItem>Zstd</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Changes are saved automatically in memory" FontStyle="Italic" Foreground="Gray"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
