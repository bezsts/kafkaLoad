<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:KafkaLoad.Desktop.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="KafkaLoad.Desktop.MainWindow"
        Title="KafkaLoad.Desktop">
    <Design.DataContext>
    <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="20" Margin="20" VerticalAlignment="Center">
        <TextBox Text="{Binding TopicName}" Watermark="Enter Topic Name"/>

        <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center"/>

        <Button Command="{Binding StartTestCommand}" Content="Start Load Test" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
