<rxui:ReactiveUserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rxui="http://reactiveui.net"
             xmlns:vm="using:KafkaLoad.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="KafkaLoad.Desktop.Views.TestScenarioEditorView"
             x:DataType="vm:TestScenarioEditorViewModel">
    <ScrollViewer>
        <StackPanel Spacing="15" Margin="20">
            
            <TextBlock Text="Create Test Scenario" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

            <StackPanel Spacing="5">
                <TextBlock Text="Scenario Name *" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Name}"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Topic Name *" FontWeight="SemiBold"/>
                <TextBox Text="{Binding TopicName}"/>
            </StackPanel>

            <Separator Height="20" Opacity="0"/>
            <TextBlock Text="Clients Configuration" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBlue}"/> 
            
            <Grid ColumnDefinitions="*, 20, *" RowDefinitions="Auto, Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Select Producer Configuration *" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Producers}"
                              SelectedItem="{Binding SelectedProducer}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Choose a producer config...">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="5">
                    <TextBlock Text="Select Consumer Configuration *" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Consumers}"
                              SelectedItem="{Binding SelectedConsumer}"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Choose a consumer config...">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Separator Height="20" Opacity="0"/>
            <TextBlock Text="Data Generation" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBlue}"/>  
            
            <Grid ColumnDefinitions="*, 20, *" RowDefinitions="Auto, Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Key Generation Strategy"/>
                    <ComboBox ItemsSource="{Binding KeyStrategyOptions}"
                              SelectedItem="{Binding KeyStrategy}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="5">
                    <TextBlock Text="Value Generation Strategy"/>
                    <ComboBox ItemsSource="{Binding ValueStrategyOptions}"
                              SelectedItem="{Binding ValueStrategy}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="5" IsVisible="{Binding IsFixedContentVisible}">
                <TextBlock Text="Message Content (JSON/Text) *" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <TextBox Text="{Binding FixedTemplate}" 
                         AcceptsReturn="True" 
                         Height="100" 
                         TextWrapping="Wrap"
                         FontFamily="Cascadia Code, Consolas, Monospace"
                         Watermark="{}{'id': 1, 'message': 'hello'}"/>
                <TextBlock Text="Note: Message Size will be calculated automatically based on this content." 
                           FontSize="12" Foreground="{DynamicResource TextSecondary}" FontStyle="Italic"/>
            </StackPanel>

            <Separator Height="20" Opacity="0"/>
            <TextBlock Text="Load Parameters" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBlue}"/>

            <Grid ColumnDefinitions="*, 20, *" RowDefinitions="Auto, Auto">
                
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
                    <TextBlock Text="Producers Count *"/>
                    <NumericUpDown Value="{Binding ProducerCount, TargetNullValue=''}" 
                                   Minimum="1" Maximum="100" Increment="1" FormatString="N0"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="5">
                    <TextBlock Text="Consumers Count"/>
                    <NumericUpDown Value="{Binding ConsumerCount, TargetNullValue=''}" 
                                   Minimum="1" Maximum="100" Increment="1" FormatString="N0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="5" Margin="0,15,0,0">
                    <TextBlock Text="Message Size (Bytes) *"/>
                    <NumericUpDown Value="{Binding MessageSize, TargetNullValue=''}" 
                                   Minimum="1" Maximum="10485760" Increment="128" FormatString="N0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="5" Margin="0,15,0,0">
                    <TextBlock Text="Duration (Seconds) *"/>
                    <NumericUpDown Value="{Binding Duration, TargetNullValue=''}" 
                                   Minimum="1" Maximum="86400" Increment="10"/>
                </StackPanel>
            </Grid>

            <Button Command="{Binding SaveCommand}" 
                    Content="Save scenario"
                    Classes="accent" 
                    HorizontalAlignment="Right"
                    Padding="20, 10"
                    Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</rxui:ReactiveUserControl>
